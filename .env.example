SILICONFLOW_API_KEY=your_siliconflow_key_here
OPENAI_API_KEY=your_openai_key_here

PRINCIPIA_LLM_BASE_URL=https://api.siliconflow.cn/v1
PRINCIPIA_OPENAI_BASE_URL=https://api.openai.com/v1

# Default model aliases used by the UI. Override only if your provider account
# exposes a different model name.
PRINCIPIA_EFFICIENT_MODEL=Qwen/Qwen2.5-7B-Instruct
PRINCIPIA_STRONG_MODEL=deepseek-ai/DeepSeek-V3
PRINCIPIA_KIMI_MODEL=Pro/moonshotai/Kimi-K2.6
PRINCIPIA_DEEPSEEK_PRO_MODEL=deepseek-ai/DeepSeek-V4-Pro
PRINCIPIA_QWEN_35B_MODEL=Qwen/Qwen3.6-35B-A3B
PRINCIPIA_QWEN_122B_MODEL=Qwen/Qwen3.5-122B-A10B
PRINCIPIA_GLM_MODEL=Pro/zai-org/GLM-5.1
PRINCIPIA_OPENAI_GPT5_PRO_MODEL=openai:gpt-5-pro
PRINCIPIA_OPENAI_GPT52_PRO_MODEL=openai:gpt-5.2-pro
PRINCIPIA_OPENAI_GPT55_MODEL=openai:gpt-5.5
PRINCIPIA_OPENAI_GPT55_PRO_20260423_MODEL=openai:gpt-5.5-pro-2026-04-23

PRINCIPIA_COST_LIMIT_CNY=1000
PRINCIPIA_REQUEST_TIMEOUT=180
PRINCIPIA_SSL_VERIFY=1
